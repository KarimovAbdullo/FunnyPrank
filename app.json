{
  "expo": {
    "name": "Funny Prank App",
    "slug": "funnyprankapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo/playstore.png",
    "scheme": "funnyprankapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.funnyprankapp.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/logo/playstore.png",
        "backgroundImage": "./src/assets/images/logo/playstore.png",
        "monochromeImage": "./src/assets/images/logo/playstore.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.funnyprankapp.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/logo/playstore.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Funny Prank App uses your location."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/logo/playstore.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4216862763820451~9506015653",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a452f78-f348-4d37-af57-145344f4459d"
      }
    },
    "owner": "karimova008"
  }
}
